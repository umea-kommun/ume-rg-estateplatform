{
  "KeyVaultUrl": "https://umekvestateplatformdev.vault.azure.net/",
  "ConnectionStrings": {
    "EstateService": "@KeyVault(estateservice-database-connection-string)"
  },
  "Features": "EstateService,ContactPersons,Documents,ErrorReport",
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Umea": "Trace",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "OpenTelemetry": {
      "LogLevel": {
        "Default": "Warning",
        "Umea.se": "Information",
        "Azure.Core": "Error",
        "Azure.Storage": "Error"
      }
    }
  },
  "AllowedHosts": "*",
  "Api": {
    "Name": "EstateService",
    "Title": "Umea.se.EstateService",
    "Description": "Api med koppling mot fastighetsystem",
    "Version": "v1.0",
    "Keys": {
      "Default": "@KeyVault(estateservice-api-key)"
    }
  },
  "Authentication": {
    "TokenServiceUrl": "https://authtokendev.umea.se",
    "Audience": "internal:mypage"
  },
  "OpenAI": {
    "Enabled": true,
    "Endpoint": "@KeyVault(openai-endpoint)",
    "Model": "gpt-5-nano"
  },
  "Pythagoras": {
    "ApiKey": "@KeyVault(pythagoras-api-key)",
    "BaseUrl": "@KeyVault(pythagoras-api-url)"
  },
  "ApplicationInsights": {
    "ConnectionString": "@KeyVault(application-insights-connection-string)"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:8080",
      "https://minasidor.dev.umea.se",
      "https://authtokendev.umea.se",
      "https://estate.dev.umea.se",
      "https://estateservice.dev.umea.se"
    ]
  },
  "DataSync": {
    "Schedule": {
      "Default": "0 3 * * *",
      "Documents": "0 3 * * *"
    }
  },
  "Search": {
    "ExcludeRoomsFromSearch": true
  },
  "ImageCache": {
    "BlobServiceUrl": "https://umestestateplatformdev.blob.core.windows.net",
    "BlobContainerName": "ume-stc-imagecache-dev"
  },
  "WorkOrder": {
    "DocumentActionTypeId": 5, // Protokoll / Handlingar
    "DocumentActionTypeStatusId": 10, // Övriga handlingar
    "FileStorage": "https://umestestateplatformdev.blob.core.windows.net",
    "FileStorageContainer": "workorder-files",

    // Pythagoras per-type defaults for fields that are MANDATORY_WHEN_CREATED.
    // Keys are Pythagoras workordertype ids. Source of truth:
    //   GET /rest/v1/workordertype/{id}/workorderfieldsetting
    "DefaultCategoryIdByType": {
      "2": 82 // BuildingService -> Innemiljö
    },
    "DefaultOperatingGroupIdByType": {
      // ErrorReport intentionally omitted: Pythagoras assigns the driftgrupp itself (see PythagorasWorkOrderCreateRequirements).
      "8": 21, // FacilityService -> Verksamhetsvaktmästare
      "9": 22  // TownHallService -> Stadshusservice
    },

    // File upload validation
    "FileValidation": {
      "MaxFileCount": 10,
      "MaxFileSizeBytes": 20971520,
      "AllowedContentTypes": [
        "image/jpeg",
        "image/png",
        "image/heic",
        "application/pdf"
      ]
    },

    // Background sync
    "ProcessingIntervalSeconds": 30,
    "MaxRetries": 5,
    "RetryBaseDelaySeconds": 60,
    "StatusCheckIntervalMinutes": 60
  }
}
